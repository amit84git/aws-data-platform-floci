FROM python:3.11-slim

WORKDIR /app

COPY floci/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt boto3 fastapi uvicorn python-multipart

COPY lambdas /app/lambdas

# FastAPI server that wraps the S3 Event Router Lambda
# Provides a REST endpoint so the EventBridge simulator can trigger it
COPY floci/router_server.py /app/router_server.py

EXPOSE 8081

CMD ["uvicorn", "router_server:app", "--host", "0.0.0.0", "--port", "8081"]