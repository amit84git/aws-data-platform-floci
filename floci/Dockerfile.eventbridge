FROM python:3.11-slim

WORKDIR /app

COPY floci/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt boto3 requests

# EventBridge Simulator - watches the raw S3 bucket and triggers the router
# In AWS, EventBridge would natively detect S3:ObjectCreated:* events and
# invoke the Lambda directly. This script replicates that locally.
COPY floci/eventbridge_simulator.py /app/eventbridge_simulator.py

CMD ["python", "eventbridge_simulator.py"]