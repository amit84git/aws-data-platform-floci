{
  "title": "FloCI Partner Ingestion Dashboard",
  "uid": "floci-ingestion",
  "version": 2,
  "schemaVersion": 36,
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "panels": [
    {
      "title": "Total Pipeline Events (Last 24h)",
      "type": "stat",
      "gridPos": {"h": 6, "w": 4, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {
          "datasource": "FloCI Audit Logs (S3)",
          "queryType": "json",
          "url": "http://floci-s3-event-router:8081/api/v1/metrics",
          "source": "url",
          "jsonPath": "$.total_events",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 80}
            ]
          },
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "title": "Good Files Routed",
      "type": "stat",
      "gridPos": {"h": 6, "w": 4, "x": 4, "y": 0},
      "id": 2,
      "targets": [
        {
          "datasource": "FloCI Audit Logs (S3)",
          "queryType": "json",
          "url": "http://floci-s3-event-router:8081/api/v1/metrics",
          "source": "url",
          "jsonPath": "$.good_files",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "green"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "none"
        }
      }
    },
    {
      "title": "Quarantined Files",
      "type": "stat",
      "gridPos": {"h": 6, "w": 4, "x": 8, "y": 0},
      "id": 3,
      "targets": [
        {
          "datasource": "FloCI Audit Logs (S3)",
          "queryType": "json",
          "url": "http://floci-s3-event-router:8081/api/v1/metrics",
          "source": "url",
          "jsonPath": "$.quarantine_files",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "red"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}]},
          "unit": "none"
        }
      }
    },
    {
      "title": "Events by Type",
      "type": "barchart",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 6},
      "id": 4,
      "targets": [
        {
          "datasource": "FloCI Audit Logs (S3)",
          "queryType": "json",
          "url": "http://floci-s3-event-router:8081/api/v1/metrics",
          "source": "url",
          "jsonPath": "$.events_by_type",
          "refId": "A",
          "columns": [
            {"selector": "event_type", "text": "Event Type", "type": "string"},
            {"selector": "count", "text": "Count", "type": "number"}
          ]
        }
      ],
      "options": {
        "orientation": "auto",
        "groupWidth": 0.7,
        "showValue": "auto",
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "none"
        }
      }
    },
    {
      "title": "Errors (Last 24h)",
      "type": "stat",
      "gridPos": {"h": 8, "w": 4, "x": 8, "y": 6},
      "id": 5,
      "targets": [
        {
          "datasource": "FloCI Audit Logs (S3)",
          "queryType": "json",
          "url": "http://floci-s3-event-router:8081/api/v1/metrics",
          "source": "url",
          "jsonPath": "$.errors",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "orange"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "none"
        }
      }
    },
    {
      "title": "Pipeline Events Timeline",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 16, "x": 0, "y": 14},
      "id": 6,
      "targets": [
        {
          "datasource": "FloCI Audit Logs (S3)",
          "queryType": "json",
          "url": "http://floci-s3-event-router:8081/api/v1/metrics",
          "source": "url",
          "jsonPath": "$.events_timeline",
          "refId": "A",
          "columns": [
            {"selector": "time", "text": "Time", "type": "string"},
            {"selector": "count", "text": "Count", "type": "number"}
          ]
        }
      ],
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "none"
        }
      }
    },
    {
      "title": "Recent Audit Logs",
      "type": "table",
      "gridPos": {"h": 10, "w": 16, "x": 0, "y": 22},
      "id": 7,
      "targets": [
        {
          "datasource": "FloCI Audit Logs (S3)",
          "queryType": "json",
          "url": "http://floci-s3-event-router:8081/api/v1/metrics",
          "source": "url",
          "jsonPath": "$",
          "refId": "A",
          "columns": [
            {"selector": "total_events", "text": "Total Events", "type": "number"},
            {"selector": "good_files", "text": "Good Files", "type": "number"},
            {"selector": "quarantine_files", "text": "Quarantined", "type": "number"},
            {"selector": "errors", "text": "Errors", "type": "number"}
          ]
        }
      ],
      "options": {
        "sortBy": [{"displayName": "Total Events", "desc": true}]
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "align": "left",
            "displayMode": "auto"
          },
          "mappings": []
        }
      }
    }
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  }
}